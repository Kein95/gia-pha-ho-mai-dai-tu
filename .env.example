# -----------------------------------------------------------------------------
# GIA PHẢ HỌ MAI ĐẠI TỪ — ENVIRONMENT VARIABLES TEMPLATE
# -----------------------------------------------------------------------------
# Hướng dẫn setup:
#   1. Tạo Vercel project, link với repo này
#   2. Vercel Storage → tạo Postgres (Neon) + Blob
#   3. Chạy: vercel env pull .env.local  (auto-inject Postgres + Blob vars)
#   4. Add AUTH_SECRET + AUTH_URL + SITE_NAME vào Vercel Environment Variables
#   5. Pull lại: vercel env pull .env.local

# Tên app hiển thị
SITE_NAME="Gia Phả Họ Mai Đại Từ"

# =============================================================================
# Vercel Postgres (auto-injected by `vercel env pull`)
# =============================================================================
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# =============================================================================
# Vercel Blob (auto-injected)
# =============================================================================
BLOB_READ_WRITE_TOKEN=

# =============================================================================
# Auth.js v5
# =============================================================================
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Local dev: http://localhost:3000 ; Production: tự pick từ VERCEL_URL
AUTH_URL=http://localhost:3000
